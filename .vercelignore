# Vercel ignore file - files to exclude from deployment
# (Git-ignored files are automatically excluded)

# Only exclude files that aren't needed for the site to run
node_modules/
.git/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Keep everything else including css/, js/, images/, audios/
# !/css/
# !/js/
# !/images/
# !/audios/
